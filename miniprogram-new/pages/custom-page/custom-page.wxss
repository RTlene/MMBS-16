.custom-page {
  min-height: 100vh;
  background: #f8fafc;
  padding: 0;
  box-sizing: border-box;
}

.state {
  text-align: center;
  color: #64748b;
  font-size: 28rpx;
  padding: 80rpx 0;
}

.state.error {
  color: #ef4444;
}

.block-image {
  width: 100%;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  background: #fff;
}

.block-text {
  background: #fff;
  color: #1e293b;
  font-size: 30rpx;
  line-height: 1.7;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.block-button {
  background: #1e293b;
  color: #fff;
  text-align: center;
  border-radius: 10rpx;
  padding: 22rpx 16rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.activity-page {
  min-height: 100vh;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.activity-poster-wrap {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
}

.activity-poster {
  width: 100%;
  display: block;
}

.activity-hotspot {
  position: absolute;
  border: 0;
  background: transparent;
  box-sizing: border-box;
}

