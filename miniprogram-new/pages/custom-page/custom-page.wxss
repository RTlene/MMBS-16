.custom-page {
  min-height: 100vh;
  background: #f8fafc;
  padding: 0;
  box-sizing: border-box;
}

.state {
  text-align: center;
  color: #64748b;
  font-size: 28rpx;
  padding: 80rpx 0;
}

.state.error {
  color: #ef4444;
}

.block-image {
  width: 100%;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  background: #fff;
}

.block-text {
  background: #fff;
  color: #1e293b;
  font-size: 30rpx;
  line-height: 1.7;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.block-button {
  background: #1e293b;
  color: #fff;
  text-align: center;
  border-radius: 10rpx;
  padding: 22rpx 16rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.activity-page {
  min-height: 100vh;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.activity-poster-wrap {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
}

.activity-poster {
  width: 100%;
  display: block;
}

.activity-hotspot {
  position: absolute;
  border: 0;
  background: transparent;
  box-sizing: border-box;
}

.share-button {
  position: fixed;
  right: 24rpx;
  bottom: 120rpx;
  width: 80rpx !important;
  height: 80rpx !important;
  min-width: 80rpx !important;
  max-width: 80rpx !important;
  min-height: 80rpx !important;
  max-height: 80rpx !important;
  border-radius: 50%;
  border: none !important;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(37, 99, 235, 0.3);
  padding: 0 !important;
  margin: 0 !important;
  line-height: 1;
  box-sizing: border-box;
  flex-shrink: 0;
  overflow: hidden;
}

.share-button::after {
  border: none;
}

.share-button-hover {
  opacity: 0.92;
}

.share-icon-img {
  width: 46rpx;
  height: 46rpx;
  display: block;
}

.share-sheet {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: none;
  z-index: 1100;
}

.share-sheet.show {
  display: block;
}

.share-sheet-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.42);
}

.share-sheet-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
}

.share-sheet-title {
  font-size: 30rpx;
  color: #111827;
  text-align: center;
  margin-bottom: 20rpx;
}

.share-sheet-btn,
.share-sheet-cancel {
  margin-bottom: 14rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.share-sheet-btn {
  background: #1f2937;
  color: #fff;
}

.share-sheet-btn-secondary {
  background: #eef2ff;
  color: #374151;
}

.share-sheet-cancel {
  background: #f3f4f6;
  color: #6b7280;
}

.qr-popup {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: none;
  z-index: 1200;
}

.qr-popup.show {
  display: block;
}

.qr-popup-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
}

.qr-popup-content {
  position: absolute;
  left: 36rpx;
  right: 36rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
}

.qr-popup-title {
  text-align: center;
  font-size: 32rpx;
  color: #111827;
  margin-bottom: 20rpx;
}

.qr-image-wrap {
  min-height: 360rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.qr-image {
  width: 100%;
  height: 360rpx;
}

.qr-hint {
  color: #6b7280;
  font-size: 26rpx;
}

.qr-actions {
  display: flex;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.qr-action-btn {
  flex: 1;
  background: #1f2937;
  color: #fff;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.qr-action-btn-secondary {
  background: #eef2ff;
  color: #374151;
}

.qr-close-btn {
  background: #f3f4f6;
  color: #6b7280;
  border-radius: 10rpx;
  font-size: 28rpx;
}

