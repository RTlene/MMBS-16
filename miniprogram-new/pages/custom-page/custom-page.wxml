<view class="custom-page">
  <view wx:if="{{loading}}" class="state">加载中...</view>
  <view wx:elif="{{error}}" class="state error">{{error}}</view>
  <view wx:elif="{{hasActivityPoster}}" class="activity-page" style="{{activityBackgroundStyle}}">
    <view class="activity-poster-wrap">
      <image class="activity-poster" src="{{activityPosterUrl}}" mode="widthFix" />
      <block wx:for="{{activityHotspots}}" wx:key="index">
        <view class="activity-hotspot" style="{{item.style}}" bindtap="onTapHotspot" data-index="{{index}}"></view>
      </block>
    </view>
  </view>
  <view wx:elif="{{!hasBlocks}}" class="state">
    页面内容为空，请在后台自定义页面中补充图片或文本模块
  </view>
  <view wx:else>
    <block wx:for="{{blocks}}" wx:key="index">
      <image wx:if="{{item.type === 'image'}}" class="block-image" src="{{item.url}}" mode="widthFix" />
      <view wx:elif="{{item.type === 'text'}}" class="block-text">{{item.text}}</view>
      <view wx:elif="{{item.type === 'button'}}" class="block-button" bindtap="onTapLink" data-url="{{item.url}}">
        {{item.text || '查看详情'}}
      </view>
      <view wx:else class="block-text">{{item.text || ''}}</view>
    </block>
  </view>

  <button
    wx:if="{{shareEnabled}}"
    class="share-button"
    bindtap="onShareButtonTap"
    hover-class="share-button-hover"
  >
    <image class="share-icon-img" src="/images/icons/share-outline.svg" mode="aspectFit" />
  </button>

  <view class="share-sheet {{showShareOptions ? 'show' : ''}}">
    <view class="share-sheet-mask" bindtap="closeShareOptions"></view>
    <view class="share-sheet-content">
      <view class="share-sheet-title">选择分享方式</view>
      <button class="share-sheet-btn" open-type="share" bindtap="onShareWechatTap">微信好友</button>
      <button class="share-sheet-btn share-sheet-btn-secondary" bindtap="onShareQrcodeTap">生成海报</button>
      <button class="share-sheet-cancel" bindtap="closeShareOptions">取消</button>
    </view>
  </view>

  <view class="qr-popup {{showQrPopup ? 'show' : ''}}">
    <view class="qr-popup-mask" bindtap="closeQrPopup"></view>
    <view class="qr-popup-content">
      <view class="qr-popup-title">分享海报</view>
      <view class="qr-image-wrap" bindtap="onPreviewQrCode">
        <image class="qr-image" src="{{qrCodeTempPath || qrCodeUrl}}" mode="aspectFit" wx:if="{{qrCodeTempPath || qrCodeUrl}}" />
        <text class="qr-hint" wx:if="{{generatingQr}}">海报生成中...</text>
      </view>
      <view class="qr-actions">
        <button class="qr-action-btn" bindtap="onSaveQrCode">保存</button>
        <button class="qr-action-btn qr-action-btn-secondary" bindtap="onShareQrCodeToWechat">微信发送</button>
      </view>
      <button class="qr-close-btn" bindtap="closeQrPopup">关闭</button>
    </view>
  </view>
  <canvas canvas-id="sharePosterCanvas" style="position:fixed;left:-9999rpx;top:-9999rpx;width:375px;height:620px;" width="375" height="620"></canvas>
</view>

