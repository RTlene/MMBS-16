<!--pages/order-detail/order-detail.wxml-->
<view class="order-detail-page">
  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:if="{{error && !loading}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
    <button class="retry-btn" bindtap="loadOrderDetail">重试</button>
  </view>

  <!-- 订单详情 -->
  <scroll-view class="order-content" scroll-y wx:if="{{order && !loading}}">
    <!-- 订单状态 -->
    <view class="status-section">
      <view class="status-icon">
        <text class="status-emoji">{{order.status === 'pending' ? '⏰' : order.status === 'paid' ? '📦' : order.status === 'shipped' ? '🚚' : (order.status === 'delivered' || order.status === 'completed') ? '✅' : '❌'}}</text>
      </view>
      <text class="status-text">{{order.statusText}}</text>
      <text class="order-no">订单号：{{order.orderNo}}</text>
    </view>

    <!-- 收货信息（配送上门） -->
    <view class="address-section" wx:if="{{order.deliveryType !== 'pickup' && order.receiverName}}">
      <view class="section-title">收货信息</view>
      <view class="address-card">
        <view class="address-row">
          <text class="receiver-name">{{order.receiverName}}</text>
          <text class="receiver-phone">{{order.receiverPhone}}</text>
        </view>
        <text class="address-text">{{order.shippingAddress}}</text>
      </view>
    </view>

    <!-- 自提门店（门店自提） -->
    <view class="store-section" wx:if="{{order.deliveryType === 'pickup' && order.store}}">
      <view class="section-title">自提门店</view>
      <view class="store-card">
        <view class="store-row">
          <text class="store-name">{{order.store.name}}</text>
        </view>
        <text class="store-address">{{order.store.address}}</text>
        <text class="store-extra" wx:if="{{order.store.phone}}">电话：{{order.store.phone}}</text>
        <text class="store-extra" wx:if="{{order.store.businessHours}}">营业时间：{{order.store.businessHours}}</text>
        <view class="store-actions">
          <text class="store-link" bindtap="onOpenStoreMap" data-store="{{order.store}}">查看地图</text>
          <text class="store-link" bindtap="onOpenExternalMap" data-store="{{order.store}}">打开外部地图</text>
        </view>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="items-section">
      <view class="section-title">商品信息</view>
      <view 
        class="item-card"
        wx:for="{{order.items}}"
        wx:key="id"
      >
        <image 
          class="item-image" 
          src="{{item.image}}" 
          mode="aspectFill"
          wx:if="{{item.image && !item.imageLoading}}"
        />
        <view class="item-image-placeholder" wx:else>
          <text class="placeholder-text">📦</text>
        </view>
        <view class="item-info">
          <text class="item-name">{{item.productName}}</text>
          <text class="item-sku" wx:if="{{item.skuName}}">{{item.skuName}}</text>
          <view class="item-meta">
            <text class="item-price">¥{{item.unitPrice}}</text>
            <text class="item-qty">x{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 核销码列表 -->
    <view class="verification-section" wx:if="{{verificationCodes.length > 0}}">
      <view class="section-title">核销码</view>
      <view class="verification-card">
        <view 
          class="verification-item"
          wx:for="{{verificationCodes}}"
          wx:key="id"
        >
          <!-- 商品信息 -->
          <view class="verification-product" wx:if="{{item.productName}}">
            <text class="product-name">{{item.productName}}</text>
            <text class="sku-name" wx:if="{{item.skuName}}">{{item.skuName}}</text>
          </view>
          
          <!-- 二维码 -->
          <view class="verification-qrcode" wx:if="{{item.qrCodePath}}">
            <image class="qrcode-image" src="{{item.qrCodePath}}" mode="aspectFit" />
            <text class="qrcode-label">二维码</text>
          </view>
          
          <!-- 条形码 -->
          <view class="verification-barcode" wx:if="{{item.barcodePath}}">
            <image class="barcode-image" src="{{item.barcodePath}}" mode="widthFix" />
            <text class="barcode-label">条形码</text>
          </view>
          
          <!-- 核销码文本 -->
          <view class="verification-code">
            <text class="code-label">核销码：</text>
            <text class="code-value">{{item.code}}</text>
            <text class="copy-btn" data-code="{{item.code}}" catchtap="onCopyVerificationCode">复制</text>
          </view>
          
          <!-- 状态信息 -->
          <view class="verification-status">
            <text class="status-text status-{{item.status}}">{{item.statusText}}</text>
            <text class="expired-text" wx:if="{{item.expiredAt}}">有效期至：{{item.expiredAt}}</text>
            <text class="used-text" wx:if="{{item.usedAt}}">使用时间：{{item.usedAt}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 退货已通过：提示邮寄并填写回寄物流 -->
    <view class="return-logistics-section" wx:if="{{order.returnStatus === 'approved' && order.refundStatus !== 'completed'}}">
      <view class="section-title">退货寄回</view>
      <view class="return-logistics-card">
        <view class="return-tip">请将退换货物<text class="highlight">自行邮寄至平台</text>。寄出后请填写下方回寄物流信息，平台确认收货后将为您退款。</view>
        <view class="return-address-block" wx:if="{{order.returnAddress}}">
          <text class="return-address-label">平台退货地址：</text>
          <text class="return-address-text">{{order.returnAddress}}</text>
        </view>
        <view class="form-row" wx:if="{{!order.returnTrackingNumber}}">
          <input class="form-input" placeholder="物流公司" value="{{returnShippingCompany}}" bindinput="onReturnShippingCompanyInput" />
          <input class="form-input" placeholder="物流单号" value="{{returnTrackingNumber}}" bindinput="onReturnTrackingNumberInput" />
          <button class="submit-logistics-btn" bindtap="onSubmitReturnLogistics" loading="{{submittingLogistics}}">提交物流</button>
        </view>
        <view class="logistics-submitted" wx:else>
          <text>已填写回寄物流：{{order.returnShippingCompany}} {{order.returnTrackingNumber}}</text>
        </view>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="info-section">
      <view class="section-title">订单信息</view>
      <view class="info-card">
        <view class="info-row">
          <text class="info-label">订单金额</text>
          <text class="info-value price">{{order.totalAmountText}}</text>
        </view>
        <view class="info-row" wx:if="{{order.paymentMethodText}}">
          <text class="info-label">支付方式</text>
          <text class="info-value">{{order.paymentMethodText}}</text>
        </view>
        <view class="info-row" wx:if="{{order.createdAtText}}">
          <text class="info-label">下单时间</text>
          <text class="info-value">{{order.createdAtText}}</text>
        </view>
        <view class="info-row" wx:if="{{order.returnStatusText && order.returnStatus !== 'none'}}">
          <text class="info-label">退货状态</text>
          <text class="info-value">{{order.returnStatusText}}</text>
        </view>
        <view class="info-row" wx:if="{{order.refundStatusText && order.refundStatus !== 'none'}}">
          <text class="info-label">退款状态</text>
          <text class="info-value">{{order.refundStatusText}}</text>
        </view>
        <view class="info-row" wx:if="{{order.returnStatus === 'approved' && order.returnAddress}}">
          <text class="info-label">退货寄回地址</text>
          <text class="info-value return-address">{{order.returnAddress}}</text>
        </view>
        <view class="info-row" wx:if="{{order.shippingCompany || order.trackingNumber}}">
          <text class="info-label">物流信息</text>
          <view class="info-value-wrapper">
            <text class="info-value" wx:if="{{order.shippingCompany}}">{{order.shippingCompany}}</text>
            <text class="info-value" wx:if="{{order.trackingNumber}}"> {{order.trackingNumber}}</text>
            <text class="logistics-link" bindtap="onViewLogistics" wx:if="{{order.trackingNumber || order.shippingCompany}}">查看物流 ›</text>
          </view>
        </view>
        <view class="info-row" wx:if="{{order.remark}}">
          <text class="info-label">订单备注</text>
          <text class="info-value">{{order.remark}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部操作栏：未发货可申请退款，已发货/已收货可申请退货 -->
  <view class="bottom-bar" wx:if="{{order && !loading}}">
    <view class="bottom-bar-hint" wx:if="{{order.status === 'paid' || order.status === 'shipped' || order.status === 'delivered'}}">
      <text wx:if="{{order.status === 'paid'}}">未发货可直接申请退款</text>
      <text wx:elif="{{order.status === 'shipped' || order.status === 'delivered'}}">已发货/已收货可申请退货（换货请在退货原因中说明）</text>
    </view>
    <button
      class="action-btn primary"
      wx:if="{{order.status === 'pending'}}"
      bindtap="onPayOrder"
    >
      立即支付
    </button>
    <button
      class="action-btn secondary"
      wx:if="{{order.status === 'pending'}}"
      bindtap="onCancelOrder"
    >
      取消订单
    </button>
    <button
      class="action-btn primary"
      wx:if="{{order.status === 'shipped' || (order.deliveryType === 'pickup' && order.status === 'paid')}}"
      bindtap="onConfirmReceive"
    >
      {{order.deliveryType === 'pickup' ? '确认自提' : '确认收货'}}
    </button>
    <!-- 已发货/已收货：申请退货（含换货说明） -->
    <button
      class="action-btn secondary"
      wx:if="{{(order.status === 'delivered' || order.status === 'shipped') && (!order.returnStatus || order.returnStatus === 'none')}}"
      bindtap="onRequestReturn"
    >
      申请退货/换货
    </button>
    <!-- 仅未发货或已取消可申请退款；退货成功由商家处理，不显示此按钮 -->
    <button
      class="action-btn secondary"
      wx:if="{{(order.status === 'paid' || order.status === 'cancelled') && (!order.refundStatus || order.refundStatus === 'none')}}"
      bindtap="onRequestRefund"
    >
      申请退款
    </button>
  </view>
</view>
