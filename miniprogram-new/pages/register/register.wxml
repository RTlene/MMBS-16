<view class="page">
  <view class="card">
    <view class="title">完善会员资料</view>
    <view class="desc">为了更好地提供服务，建议授权获取头像昵称和手机号。若拒绝授权，将使用随机昵称作为默认资料。</view>

    <view class="section">
      <button class="btn" bindtap="onGetProfile">获取头像昵称</button>
      <view class="hint" wx:if="{{profileStatus}}">{{profileStatus}}</view>
    </view>

    <view class="section">
      <button class="btn btn-primary" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">获取手机号</button>
      <view class="hint" wx:if="{{phoneStatus}}">{{phoneStatus}}</view>
    </view>

    <view class="actions">
      <button class="btn btn-ghost" bindtap="onSkip">暂不授权</button>
      <button class="btn btn-primary" bindtap="onFinish">完成</button>
    </view>
  </view>
</view>

