<view class="page">
  <view class="card">
    <view class="title">完善会员资料</view>
    <view class="desc">为了更好地提供服务，建议完善头像、昵称和手机号。若拒绝授权，将使用随机昵称作为默认资料。</view>

    <view class="section">
      <button class="btn btn-primary" bindtap="onGetProfile">一键授权获取头像昵称</button>
      <button class="btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">选择头像</button>
      <input class="input" value="{{nickname}}" placeholder="请输入昵称（必填）" bindinput="onNicknameInput" maxlength="20" />
      <button class="btn" bindtap="onSaveProfile">保存头像昵称</button>
    </view>

    <view class="section">
      <button class="btn btn-primary" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">获取手机号</button>
    </view>

    <view class="actions">
      <button class="btn btn-ghost" bindtap="onSkip">暂不授权</button>
      <button class="btn btn-primary" bindtap="onFinish">完成</button>
    </view>
  </view>
</view>

