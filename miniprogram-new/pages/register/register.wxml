<view class="page">
  <view class="card">
    <view class="title">完善会员资料</view>
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar" src="{{avatarDisplayUrl || defaultAvatar}}" mode="aspectFill" />
    </button>

    <view class="row">
      <text class="label">昵称</text>
      <input
        class="nickname-input"
        type="nickname"
        value="{{nickname}}"
        placeholder="点击获取微信用户名"
        bindinput="onNicknameInput"
        bindchange="onNicknameInput"
      />
    </view>

    <view class="row phone-row">
      <text class="label">手机号</text>
      <text class="value">{{phone || '未绑定'}}</text>
    </view>

    <view class="phone-action">
      <button class="btn btn-primary" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">获取手机号</button>
    </view>

    <view class="actions">
      <button class="btn btn-primary btn-full" bindtap="onSaveProfile">完成</button>
    </view>
  </view>
</view>

