<view class="page">
  <view class="card">
    <view class="title">完善会员资料</view>
    <image class="avatar" src="{{avatarDisplayUrl || defaultAvatar}}" mode="aspectFill" />

    <view class="row" bindtap="onTapNickname">
      <text class="label">昵称</text>
      <text class="value">{{nickname || '点击获取微信用户名'}}</text>
    </view>

    <view class="row phone-row">
      <text class="label">手机号</text>
      <text class="value">{{phone || '未绑定'}}</text>
    </view>

    <view class="phone-action">
      <button class="btn btn-primary" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">获取手机号</button>
    </view>

    <view class="actions">
      <button class="btn btn-primary btn-full" bindtap="onFinish">完成</button>
    </view>
  </view>
</view>

