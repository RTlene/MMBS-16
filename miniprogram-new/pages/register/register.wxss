.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: block;
  margin: 28rpx auto 18rpx;
  background: #f3f4f6;
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  width: 100%;
  display: flex;
  justify-content: center;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.label {
  font-size: 28rpx;
  color: #6b7280;
}

.value {
  font-size: 28rpx;
  color: #111827;
  max-width: 60%;
  text-align: right;
}

.nickname-input {
  width: 60%;
  font-size: 28rpx;
  color: #111827;
  text-align: right;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
}

.phone-row {
  border-top: 1rpx solid #f0f0f0;
}

.phone-action {
  margin-top: 18rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.btn {
  flex: 1;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  color: #111827;
  border-radius: 12rpx;
  padding: 20rpx 18rpx;
  font-size: 28rpx;
}

.btn-primary {
  background: #2563eb;
  border-color: #2563eb;
  color: #fff;
}

.btn-full {
  flex: 1;
  width: 100%;
}

.btn-ghost {
  background: #fff;
  border-color: #d1d5db;
  color: #374151;
}

.btn::after {
  border: none;
}

