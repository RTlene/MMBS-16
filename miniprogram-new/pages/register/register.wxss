.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.section {
  margin-top: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.input {
  margin-top: 12rpx;
  padding: 18rpx 16rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #111827;
  background: #fff;
}

.hint {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.btn {
  flex: 1;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  color: #111827;
  border-radius: 12rpx;
  padding: 20rpx 18rpx;
  font-size: 28rpx;
}

.btn-primary {
  background: #2563eb;
  border-color: #2563eb;
  color: #fff;
}

.btn-ghost {
  background: #fff;
  border-color: #d1d5db;
  color: #374151;
}

.btn::after {
  border: none;
}

