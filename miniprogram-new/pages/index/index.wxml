<!--pages/index/index.wxml - 首页：1大海报 2热门分类 3横幅(无图隐藏) 4热门商品 5资讯 6精选推荐-->
<view class="index-page">
  <!-- 浮动搜索栏 -->
  <view class="search-bar" style="opacity: {{searchOpacity}};">
    <view class="search-input" bindtap="onSearchTap">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索商品</text>
    </view>
  </view>

  <!-- 1. 大海报轮播（后台：横幅管理 - 展示位置选「大海报」） -->
  <view class="poster-section" wx:if="{{banners.length > 0}}">
    <swiper
      class="poster-swiper"
      indicator-dots="{{true}}"
      indicator-color="rgba(255,255,255,0.4)"
      indicator-active-color="#fff"
      autoplay="{{true}}"
      interval="{{4500}}"
      duration="{{400}}"
      circular="{{true}}"
      bindchange="onPosterSwiperChange"
    >
      <swiper-item wx:for="{{banners}}" wx:key="id" bindtap="onBannerTap" data-index="{{index}}">
        <image class="poster-image" src="{{item.imageUrl}}" mode="aspectFill" binderror="onPosterImageError" data-index="{{index}}" show-menu-by-longpress="{{false}}" loading="eager" />
        <view class="poster-placeholder" wx:if="{{item.loadError}}">
          <text class="placeholder-icon">📷</text>
          <text class="placeholder-text">图片加载失败</text>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 2. 热门分类（后台：商品分类管理） -->
  <view class="category-section" wx:if="{{categories.length > 0}}">
    <view class="category-grid">
      <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="onCategoryTap" data-id="{{item.id}}">
        <image class="category-icon" src="{{item.icon || '../../images/category-default.png'}}" mode="aspectFit" />
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 3. 横幅（后台：轮播图管理 - 位置选「活动横幅」，无图时隐藏） -->
  <view class="activity-banner-section" wx:if="{{activityBanners.length > 0}}">
    <swiper
      class="activity-swiper"
      indicator-dots="{{true}}"
      indicator-color="rgba(0,0,0,0.12)"
      indicator-active-color="#1E293B"
      autoplay="{{true}}"
      interval="{{4000}}"
      duration="{{400}}"
      circular="{{true}}"
      bindchange="onActivityBannerChange"
    >
      <swiper-item wx:for="{{activityBanners}}" wx:key="id" bindtap="onActivityBannerTap" data-index="{{index}}">
        <image class="activity-banner-image" src="{{item.imageUrl}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
  </view>

  <!-- 4. 热门商品（后台：商品管理 - 勾选「热门」） -->
  <view class="product-section" wx:if="{{hotProducts.length > 0}}">
    <view class="section-header">
      <view class="section-title">
        <image class="title-icon-img" src="/images/icons/star.svg" mode="aspectFit" />
        <text class="title-text">热门商品</text>
      </view>
      <view class="section-more" bindtap="onMoreHotTap">
        <text class="more-text">更多</text>
        <text class="more-arrow">›</text>
      </view>
    </view>
    <view class="product-grid">
      <view class="product-item" wx:for="{{hotProducts}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
        <view class="product-image-wrapper">
          <image class="product-image" src="{{item.images[0]}}" mode="aspectFill" />
          <view class="product-hot-tag">热</view>
        </view>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="product-bottom">
            <view class="product-price">
              <text class="price-symbol">¥</text>
              <text class="price-value" wx:if="{{item.priceMin != null && item.priceMax != null && item.priceMin !== item.priceMax}}">{{item.priceMin}} - {{item.priceMax}}</text>
              <text class="price-value" wx:else>{{item.price}}</text>
            </view>
            <text class="product-sales">已售{{item.sales || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 5. 资讯列表（后台：文章/资讯管理，首页展示最多 5 条） -->
  <view class="article-section" wx:if="{{homeArticles.length > 0}}">
    <view class="section-header">
      <view class="section-title">
        <image class="title-icon-img" src="/images/icons/article.svg" mode="aspectFit" />
        <text class="title-text">资讯</text>
      </view>
      <view class="section-more" bindtap="onMoreArticlesTap">
        <text class="more-text">更多</text>
        <text class="more-arrow">›</text>
      </view>
    </view>
    <view class="article-list">
      <view class="article-item" wx:for="{{homeArticles}}" wx:key="id" bindtap="onArticleTap" data-id="{{item.id}}">
        <image class="article-cover" src="{{item.coverImage}}" mode="aspectFill" wx:if="{{item.coverImage}}" />
        <view class="article-cover placeholder" wx:else><text class="article-placeholder-text">图</text></view>
        <view class="article-info">
          <text class="article-title">{{item.title}}</text>
          <text class="article-summary" wx:if="{{item.summary}}">{{item.summary}}</text>
          <text class="article-time">{{item.publishTime}}</text>
        </view>
        <text class="article-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 6. 精选推荐（后台：商品管理 - 勾选「推荐」） -->
  <view class="product-section" wx:if="{{recommendProducts.length > 0}}">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">⭐</text>
        <text class="title-text">精选推荐</text>
      </view>
      <view class="section-more" bindtap="onMoreRecommendTap">
        <text class="more-text">更多</text>
        <text class="more-arrow">›</text>
      </view>
    </view>
    <view class="product-grid">
      <view class="product-item" wx:for="{{recommendProducts}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
        <view class="product-image-wrapper">
          <image class="product-image" src="{{item.images[0]}}" mode="aspectFill" />
          <view class="product-tag" wx:if="{{item.tags && item.tags.length > 0}}">{{item.tags[0]}}</view>
        </view>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="product-bottom">
            <view class="product-price">
              <text class="price-symbol">¥</text>
              <text class="price-value" wx:if="{{item.priceMin != null && item.priceMax != null && item.priceMin !== item.priceMax}}">{{item.priceMin}} - {{item.priceMax}}</text>
              <text class="price-value" wx:else>{{item.price}}</text>
            </view>
            <text class="product-sales">已售{{item.sales || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 7. 全部商品（首页底部，向下滑后懒加载，触底每次加载6个） -->
  <view class="product-section" wx:if="{{allLoadedOnce}}">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">🛍️</text>
        <text class="title-text">全部商品</text>
      </view>
    </view>
    <view class="product-grid" wx:if="{{allProducts.length > 0}}">
      <view class="product-item" wx:for="{{allProducts}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
        <view class="product-image-wrapper">
          <image class="product-image" src="{{item.images[0]}}" mode="aspectFill" />
        </view>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="product-bottom">
            <view class="product-price">
              <text class="price-symbol">¥</text>
              <text class="price-value" wx:if="{{item.priceMin != null && item.priceMax != null && item.priceMin !== item.priceMax}}">{{item.priceMin}} - {{item.priceMax}}</text>
              <text class="price-value" wx:else>{{item.price}}</text>
            </view>
            <text class="product-sales">已售{{item.sales || 0}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="all-products-empty" wx:if="{{allProducts.length === 0 && !allLoading}}">
      <text>暂无商品</text>
    </view>
    <view class="all-products-loading" wx:if="{{allLoading}}">
      <text>加载更多商品中...</text>
    </view>
    <view class="all-products-end" wx:if="{{allProducts.length > 0 && !allHasMore && !allLoading}}">
      <text>已经到底了</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}"><text>加载中...</text></view>

  <!-- 错误状态 -->
  <view class="error-state" wx:if="{{!loading && hasError && dataLoaded}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error || '加载失败，请稍后重试'}}</text>
    <button class="retry-btn" bindtap="loadPageData">重试</button>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && !hasError && dataLoaded && recommendProducts.length === 0 && hotProducts.length === 0}}">
    <text class="empty-icon">📦</text>
    <text class="empty-text">暂无商品</text>
    <text class="empty-desc">商品正在准备中，敬请期待</text>
  </view>

  <view class="empty-category" wx:if="{{!loading && !hasError && dataLoaded && categories.length === 0}}">
    <text class="empty-category-text">暂无分类</text>
  </view>

  <view class="safe-area-bottom"></view>

  <view class="campaign-popup-mask" wx:if="{{showCampaignPopup}}" bindtap="closeCampaignPopup"></view>
  <view class="campaign-popup-wrap" wx:if="{{showCampaignPopup}}">
    <view class="campaign-popup-card">
      <swiper
        class="campaign-popup-swiper"
        indicator-dots="{{campaignPopupActivities.length > 1}}"
        autoplay="{{campaignPopupActivities.length > 1}}"
        circular="{{campaignPopupActivities.length > 1}}"
        bindchange="onCampaignPopupActivityChange"
      >
        <swiper-item wx:for="{{campaignPopupActivities}}" wx:key="id">
          <view class="campaign-popup-activity" bindtap="onCampaignPopupTap" data-index="{{index}}">
            <image class="campaign-popup-image" src="{{item.coverImage}}" mode="widthFix"></image>
          </view>
        </swiper-item>
      </swiper>
    </view>
    <button class="campaign-popup-close" bindtap="closeCampaignPopup">×</button>
  </view>
</view>
