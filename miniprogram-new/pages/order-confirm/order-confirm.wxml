<!--pages/order-confirm/order-confirm.wxml-->
<view class="order-confirm-page">
  <!-- 配送方式 -->
  <view class="section-block delivery-type-block">
    <view class="block-title">
      <text class="block-title-icon">🚚</text>
      <text class="block-title-text">配送方式</text>
    </view>
    <view class="delivery-type-card">
      <view 
        class="delivery-option {{deliveryType === 'delivery' ? 'active' : ''}} {{deliveryAllowExpress ? '' : 'disabled'}}"
        data-type="delivery"
        bindtap="onDeliveryTypeChange"
      >
        <text class="option-label">配送上门</text>
        <text class="option-desc">快递配送到家</text>
      </view>
      <view 
        class="delivery-option {{deliveryType === 'pickup' ? 'active' : ''}} {{deliveryAllowPickup ? '' : 'disabled'}}"
        data-type="pickup"
        bindtap="onDeliveryTypeChange"
      >
        <text class="option-label">门店自提</text>
        <text class="option-desc">到店自提</text>
      </view>
    </view>
    <view class="delivery-constraint-hint" wx:if="{{deliveryConstraintHint}}">{{deliveryConstraintHint}}</view>
  </view>

  <!-- 收货信息（仅配送上门显示） -->
  <view class="section-block address-block" wx:if="{{deliveryType === 'delivery'}}">
    <view class="block-title">
      <text class="block-title-icon">📍</text>
      <text class="block-title-text">收货信息</text>
    </view>
    <view class="address-card">
      <view class="field choose-address" bindtap="onChooseSavedAddress">
        <text class="choose-text">{{selectedAddressId ? '更换已保存地址' : '选择已保存地址'}}</text>
        <text class="choose-arrow">›</text>
      </view>
      <view class="field">
        <text class="field-label">收货人</text>
        <input 
          class="field-input"
          placeholder="收货人姓名（最多50字）"
          value="{{receiverName}}"
          data-field="receiverName"
          maxlength="50"
          bindinput="onInputChange"
        />
        <text class="field-hint">最多50字</text>
      </view>
      <view class="field">
        <text class="field-label">手机号</text>
        <input 
          class="field-input"
          placeholder="手机号（最多20位）"
          value="{{receiverPhone}}"
          data-field="receiverPhone"
          bindinput="onInputChange"
          bindblur="onReceiverPhoneBlur"
          type="number"
          maxlength="20"
        />
        <text class="field-hint field-hint-error" wx:if="{{receiverPhoneError}}">{{receiverPhoneError}}</text>
      </view>
      <view class="field multi-line">
        <text class="field-label">收货地址</text>
        <textarea
          class="field-textarea"
          placeholder="详细收货地址（最多200字）"
          value="{{shippingAddress}}"
          data-field="shippingAddress"
          maxlength="200"
          bindinput="onInputChange"
          auto-height
        />
        <text class="field-hint">最多200字</text>
      </view>
      <view class="field map-choose-row">
        <text class="field-label">地图选址</text>
        <button class="map-btn" size="mini" bindtap="onChooseLocation">选点</button>
      </view>
    </view>
  </view>

  <!-- 自提门店（仅门店自提显示） -->
  <view class="section-block store-block" wx:if="{{deliveryType === 'pickup'}}">
    <view class="block-title">
      <text class="block-title-icon">🏪</text>
      <text class="block-title-text">自提门店</text>
    </view>
    <view class="store-card" bindtap="onShowStorePicker">
      <view class="store-selected" wx:if="{{selectedStore}}">
        <text class="store-name">{{selectedStore.name}}</text>
        <text class="store-address">{{selectedStore.address}}</text>
        <text class="store-distance" wx:if="{{selectedStore.distance != null}}">约 {{selectedStore.distance}} km</text>
        <view class="store-actions">
          <text class="store-action-link" catchtap="onOpenStoreMap" data-store-id="{{selectedStore.id}}">查看地图</text>
          <text class="store-action-link" catchtap="onOpenExternalMap" data-store-id="{{selectedStore.id}}">打开外部地图</text>
        </view>
      </view>
      <view class="store-choose-placeholder" wx:else>
        <text class="choose-text">请选择自提门店</text>
        <text class="choose-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="section-block items-section">
    <view class="block-title">
      <text class="block-title-icon">🛒</text>
      <text class="block-title-text">商品信息</text>
    </view>
    <view class="items-card">
    <view 
      class="item-card"
      wx:for="{{items}}"
      wx:key="skuId"
    >
      <image class="item-image" src="{{item.image}}" mode="aspectFill" />
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-sku" wx:if="{{item.skuName}}">{{item.skuName}}</text>
        <text class="item-delivery-attr" wx:if="{{item.deliveryConstraintText}}">
          配送属性：{{item.deliveryConstraintText}}
        </text>
        <view class="item-meta">
          <text class="item-price">¥{{item.price}}</text>
          <text class="item-qty">x{{item.quantity}}</text>
        </view>
        <view class="item-gift-preview" wx:if="{{item.promoGiftItems && item.promoGiftItems.length > 0}}">
          <view class="item-gift-row" wx:for="{{item.promoGiftItems}}" wx:key="key">
            <image class="item-gift-image" src="{{item.productImage || '/images/default-product.svg'}}" mode="aspectFill" />
            <view class="item-gift-info">
              <view class="item-gift-title-line">
                <text class="item-gift-tag">活动赠品</text>
                <text class="item-gift-name">{{item.productName}}</text>
              </view>
              <view class="item-gift-price-line">
                <text class="item-gift-price-old">¥{{item.originalPrice}}</text>
                <text class="item-gift-price-now">¥0.00</text>
                <text class="item-gift-qty">x{{item.quantity}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
    </view>
    <view class="gift-list-card" wx:if="{{giftItems.length > 0}}">
      <view class="gift-list-title">🎁 满赠赠品</view>
      <view class="gift-item" wx:for="{{giftItems}}" wx:key="key">
        <image class="gift-image" src="{{item.productImage || '/images/default-product.svg'}}" mode="aspectFill" />
        <view class="gift-info">
          <text class="gift-name">{{item.productName}}</text>
          <text class="gift-sku" wx:if="{{item.skuId}}">SKU#{{item.skuId}}</text>
        </view>
        <text class="gift-qty">x{{item.quantity}}</text>
      </view>
    </view>
  </view>

  <!-- 价格明细与公式 -->
  <view class="section-block summary-section">
    <view class="block-title">
      <text class="block-title-icon">💰</text>
      <text class="block-title-text">订单明细</text>
    </view>
    <view class="summary-card">
    <view class="benefit-mode-row">
      <text class="summary-label">优惠方式</text>
      <view class="benefit-mode-group">
        <view class="benefit-mode-item {{benefitMode === 'promotion' ? 'active' : ''}}" data-mode="promotion" bindtap="onBenefitModeChange">促销</view>
        <view class="benefit-mode-item {{benefitMode === 'coupon' ? 'active' : ''}}" data-mode="coupon" bindtap="onBenefitModeChange">优惠券</view>
        <view class="benefit-mode-item {{benefitMode === 'member' ? 'active' : ''}}" data-mode="member" bindtap="onBenefitModeChange">会员折扣</view>
      </view>
    </view>
    <view class="promotion-picker-row" wx:if="{{benefitMode === 'promotion'}}">
      <view class="promotion-picker-title">选择促销</view>
      <view class="promotion-picker-list" wx:if="{{availablePromotions.length > 0}}">
        <view class="promotion-picker-item {{selectedPromotion && selectedPromotion.id == item.id ? 'active' : ''}}" wx:for="{{availablePromotions}}" wx:key="id" data-id="{{item.id}}" bindtap="onSelectPromotion">
          <text class="promotion-picker-name">{{item.name}}</text>
          <text class="promotion-picker-desc">{{item.typeText || item.type}}</text>
        </view>
      </view>
      <text class="promotion-picker-empty" wx:else>当前商品暂无可选促销</text>
      <text class="promotion-picker-hint" wx:if="{{availablePromotions.length > 0 && !selectedPromotion}}">未选择时将按默认规则自动匹配促销</text>
    </view>
    <view class="summary-row" wx:if="{{pricingLoading}}">
      <text class="summary-label">正在计算价格…</text>
    </view>
    <block wx:else>
    <view class="summary-row">
      <text class="summary-label">商品原价</text>
      <text class="summary-value">¥{{orderOriginalAmount || originalAmount}}</text>
    </view>
    <view class="summary-row promotion-row" wx:if="{{benefitMode === 'promotion' && promotionDiscountTotal > 0}}">
      <view class="promotion-left">
        <text class="summary-label">促销优惠</text>
        <view class="promotion-detail" wx:for="{{pricingDiscounts}}" wx:key="name">
          <text class="promotion-detail-name">{{item.name}}</text>
          <text class="promotion-detail-amount">-¥{{item.amount}}</text>
        </view>
      </view>
      <text class="summary-value discount">-¥{{promotionDiscountTotal}}</text>
    </view>
    <view class="summary-row promotion-invalidated-row" wx:if="{{benefitMode === 'coupon' && promotionDiscountInvalidatedByCoupon > 0}}">
      <view class="promotion-left">
        <text class="summary-label">促销优惠</text>
        <text class="promotion-invalidated-hint">使用不可与促销同享的优惠券，本单促销不生效</text>
      </view>
      <text class="summary-value discount promotion-strikethrough">-¥{{promotionDiscountInvalidatedByCoupon}}</text>
    </view>
    <view class="summary-row" wx:if="{{(benefitMode === 'promotion' && promotionDiscountTotal > 0) || (benefitMode === 'coupon' && promotionDiscountInvalidatedByCoupon > 0)}}">
      <text class="summary-label">小计（促销后）</text>
      <text class="summary-value">¥{{subtotalAfterPromo}}</text>
    </view>
    <view class="summary-row" wx:if="{{benefitMode === 'member' && memberDiscountTotal > 0}}">
      <text class="summary-label">会员折扣</text>
      <text class="summary-value discount">-¥{{memberDiscountTotal}}</text>
    </view>
    </block>
    
    <!-- 优惠券选择 -->
    <view class="summary-row coupon-row {{benefitMode !== 'coupon' ? 'coupon-row-disabled' : ''}}" bindtap="onShowCouponPicker">
      <view class="coupon-left">
        <text class="summary-label">优惠券</text>
        <text class="coupon-desc" wx:if="{{selectedCoupon}}">{{selectedCoupon.name}}</text>
        <text class="coupon-desc placeholder" wx:else>{{benefitMode === 'coupon' ? '选择优惠券' : '切换到“优惠券”后可选'}}</text>
      </view>
      <view class="coupon-right">
        <text class="coupon-discount" wx:if="{{selectedCoupon && discountAmount > 0}}">-¥{{discountAmount}}</text>
        <text class="coupon-arrow">></text>
      </view>
    </view>
    
    <!-- 佣金抵扣 -->
    <view class="summary-row deduction-row">
      <view class="deduction-left">
        <text class="summary-label">佣金抵扣</text>
        <text class="deduction-desc" wx:if="{{availableCommission > 0}}">可用：¥{{availableCommission}}</text>
        <text class="deduction-desc placeholder" wx:else>暂无可用佣金</text>
      </view>
      <view class="deduction-right">
        <switch 
          checked="{{useCommission > 0}}" 
          bindchange="onToggleCommission"
          disabled="{{availableCommission <= 0 || totalAmount <= 0}}"
          color="#ff6b35"
        />
        <text class="deduction-amount" wx:if="{{useCommission > 0}}">-¥{{commissionDeduction}}</text>
      </view>
    </view>
    <view class="deduction-input-row" wx:if="{{useCommission > 0}}">
      <text class="deduction-input-label">使用佣金：</text>
      <input 
        class="deduction-input"
        type="digit"
        placeholder="请输入使用金额"
        value="{{useCommission}}"
        bindinput="onCommissionInput"
      />
      <text class="deduction-input-unit">元</text>
    </view>
    
    <!-- 积分抵扣 -->
    <view class="summary-row deduction-row">
      <view class="deduction-left">
        <text class="summary-label">积分抵扣</text>
        <text class="deduction-desc" wx:if="{{availablePoints > 0}}">可用：{{availablePoints}}积分</text>
        <text class="deduction-desc placeholder" wx:else>暂无可用积分</text>
      </view>
      <view class="deduction-right">
        <switch 
          checked="{{usePoints > 0}}" 
          bindchange="onTogglePoints"
          disabled="{{availablePoints <= 0 || totalAmount <= 0}}"
          color="#ff6b35"
        />
        <text class="deduction-amount" wx:if="{{usePoints > 0}}">-¥{{pointsDeduction}}</text>
      </view>
    </view>
    <view class="deduction-input-row" wx:if="{{usePoints > 0}}">
      <text class="deduction-input-label">使用积分：</text>
      <input 
        class="deduction-input"
        type="number"
        placeholder="请输入使用积分"
        value="{{usePoints}}"
        bindinput="onPointsInput"
      />
      <text class="deduction-input-unit">积分（100积分=1元）</text>
    </view>
    
    <!-- 价格计算公式 -->
    <view class="price-formula-block">
      <view class="formula-title">价格计算</view>
      <view class="formula-line">
        <text class="formula-text">商品原价 ¥{{orderOriginalAmount || originalAmount}}</text>
      </view>
      <view class="formula-line" wx:if="{{promotionDiscountTotal > 0}}">
        <text class="formula-text formula-minus">- 促销优惠 ¥{{promotionDiscountTotal}}</text>
      </view>
      <view class="formula-line formula-invalidated" wx:if="{{promotionDiscountInvalidatedByCoupon > 0}}">
        <text class="formula-text formula-minus formula-strikethrough">- 促销优惠 ¥{{promotionDiscountInvalidatedByCoupon}}</text>
        <text class="formula-hint">（不可与当前优惠券同享，已失效）</text>
      </view>
      <view class="formula-line" wx:if="{{discountAmount > 0}}">
        <text class="formula-text formula-minus">- 优惠券 ¥{{discountAmount}}</text>
      </view>
      <view class="formula-line" wx:if="{{commissionDeduction > 0}}">
        <text class="formula-text formula-minus">- 佣金抵扣 ¥{{commissionDeduction}}</text>
      </view>
      <view class="formula-line" wx:if="{{pointsDeduction > 0}}">
        <text class="formula-text formula-minus">- 积分抵扣 ¥{{pointsDeduction}}</text>
      </view>
      <view class="formula-line formula-result">
        <text class="formula-text">= 实付 ¥{{totalAmount}}</text>
      </view>
    </view>
    
    <!-- 价格明细（折叠式，与公式一致） -->
    <view class="price-detail" wx:if="{{discountAmount > 0 || commissionDeduction > 0 || pointsDeduction > 0 || promotionDiscountTotal > 0 || promotionDiscountInvalidatedByCoupon > 0}}">
      <view class="detail-row">
        <text class="detail-label">商品原价</text>
        <text class="detail-value">¥{{orderOriginalAmount || originalAmount}}</text>
      </view>
      <view class="detail-row discount-row" wx:if="{{promotionDiscountTotal > 0}}">
        <text class="detail-label">促销优惠</text>
        <text class="detail-value discount">-¥{{promotionDiscountTotal}}</text>
      </view>
      <view class="detail-row discount-row detail-row-invalidated" wx:if="{{promotionDiscountInvalidatedByCoupon > 0}}">
        <text class="detail-label">促销优惠（已失效）</text>
        <text class="detail-value discount detail-strikethrough">-¥{{promotionDiscountInvalidatedByCoupon}}</text>
      </view>
      <view class="detail-row discount-row" wx:if="{{discountAmount > 0}}">
        <text class="detail-label">优惠券</text>
        <text class="detail-value discount">-¥{{discountAmount}}</text>
      </view>
      <view class="detail-row discount-row" wx:if="{{commissionDeduction > 0}}">
        <text class="detail-label">佣金抵扣</text>
        <text class="detail-value discount">-¥{{commissionDeduction}}</text>
      </view>
      <view class="detail-row discount-row" wx:if="{{pointsDeduction > 0}}">
        <text class="detail-label">积分抵扣</text>
        <text class="detail-value discount">-¥{{pointsDeduction}}</text>
      </view>
    </view>
    
    <view class="remark-row">
      <text class="remark-label">订单备注</text>
      <textarea
        class="remark-input"
        placeholder="选填，如配送时间、口味等"
        value="{{remark}}"
        data-field="remark"
        bindinput="onInputChange"
      />
    </view>
    </view>
  </view>

  <!-- 优惠券选择弹窗 -->
  <view class="coupon-picker-mask" wx:if="{{showCouponPicker}}" bindtap="onHideCouponPicker">
    <view class="coupon-picker" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择优惠券</text>
        <text class="picker-close" bindtap="onHideCouponPicker">×</text>
      </view>
      <scroll-view class="picker-content" scroll-y>
        <view 
          class="coupon-item {{selectedCoupon && (selectedCoupon.id === item.id || selectedCoupon.id == item.id) ? 'selected' : ''}}"
          wx:for="{{availableCoupons}}"
          wx:key="id"
          bindtap="onSelectCoupon"
          data-coupon="{{item}}"
          data-id="{{item.id}}"
        >
          <view class="coupon-info">
            <text class="coupon-name">{{item.name}}</text>
            <text class="coupon-desc">使用门槛：{{item.thresholdText || item.description || '无门槛'}}</text>
            <text class="coupon-time" wx:if="{{item.validRange}}">有效期：{{item.validRange}}</text>
          </view>
          <view class="coupon-action">
            <text class="coupon-discount-value">{{item.displayValue}}</text>
            <button 
              wx:if="{{selectedCoupon && (selectedCoupon.id === item.id || selectedCoupon.id == item.id)}}"
              class="coupon-cancel-btn"
              catchtap="onRemoveCoupon"
            >取消使用</button>
          </view>
        </view>
        <view class="no-coupon" wx:if="{{availableCoupons.length === 0}}">
          <text class="no-coupon-text">暂无可用的优惠券</text>
        </view>
      </scroll-view>
      <view class="picker-footer" wx:if="{{selectedCoupon}}">
        <button class="remove-coupon-btn" bindtap="onRemoveCoupon">不使用优惠券</button>
      </view>
    </view>
  </view>

  <!-- 门店选择弹窗 -->
  <view class="store-picker-mask" wx:if="{{showStorePicker}}" bindtap="onHideStorePicker">
    <view class="store-picker" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择自提门店</text>
        <text class="picker-close" bindtap="onHideStorePicker">×</text>
      </view>
      <scroll-view class="store-picker-list" scroll-y>
        <view 
          class="store-picker-item {{selectedStore && selectedStore.id === item.id ? 'selected' : ''}}"
          wx:for="{{storeList}}"
          wx:key="id"
          bindtap="onSelectStore"
          data-store-id="{{item.id}}"
        >
          <view class="store-item-main">
            <text class="store-item-name">{{item.name}}</text>
            <text class="store-item-address">{{item.address}}</text>
            <text class="store-item-distance" wx:if="{{item.distance != null}}">约 {{item.distance}} km</text>
          </view>
          <view class="store-item-actions">
            <text class="store-item-btn" catchtap="onOpenStoreMap" data-store-id="{{item.id}}">地图</text>
            <text class="store-item-btn" catchtap="onOpenExternalMap" data-store-id="{{item.id}}">外部地图</text>
          </view>
        </view>
        <view class="no-store" wx:if="{{storeList.length === 0}}">
          <text>暂无可选自提门店</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="total-info">
      <text class="total-label">合计：</text>
      <text class="total-amount">¥{{totalAmount}}</text>
    </view>
    <button
      class="submit-btn"
      bindtap="onSubmitOrder"
      loading="{{submitting}}"
      disabled="{{submitting}}"
    >
      提交订单
    </button>
  </view>
</view>


