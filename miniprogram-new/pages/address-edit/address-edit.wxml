<view class="address-edit-page">
  <view class="form-item">
    <text class="label">收货人</text>
    <input 
      placeholder="收货人姓名（最多50字）" 
      value="{{formData.name}}" 
      data-field="name" 
      maxlength="50"
      bindinput="onInput" 
    />
    <text class="hint">最多50字</text>
  </view>
  <view class="form-item">
    <text class="label">手机号</text>
    <input 
      placeholder="手机号（最多20位）" 
      type="number" 
      value="{{formData.phone}}" 
      data-field="phone" 
      maxlength="20"
      bindinput="onInput"
      bindblur="onPhoneBlur"
    />
    <text class="hint hint-error" wx:if="{{phoneError}}">{{phoneError}}</text>
  </view>
  <view class="form-item">
    <text class="label">省市区</text>
    <picker mode="region" bindchange="onRegionChange">
      <view class="picker-text">{{formData.region || '请选择省市区（最多200字）'}}</view>
    </picker>
    <text class="hint">最多200字</text>
  </view>
  <view class="form-item">
    <text class="label">详细地址</text>
    <input 
      placeholder="街道楼栋门牌（最多200字）" 
      value="{{formData.detail}}" 
      data-field="detail" 
      maxlength="200"
      bindinput="onInput" 
    />
    <text class="hint">最多200字</text>
  </view>
  <view class="form-item">
    <text class="label">地图选址</text>
    <button class="map-btn" size="mini" type="primary" bindtap="onChooseLocation">选择地点</button>
  </view>

  <button class="save-btn" type="primary" loading="{{saving}}" bindtap="onSave">保存</button>
</view>

