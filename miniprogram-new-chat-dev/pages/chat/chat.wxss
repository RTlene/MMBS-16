.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}
.messages {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx;
}
.loading-tip, .empty-tip {
  text-align: center;
  color: #999;
  padding: 40rpx;
  font-size: 28rpx;
}
.msg-row {
  margin-bottom: 24rpx;
  display: flex;
}
.msg-row.mine {
  justify-content: flex-end;
}
.msg-row.theirs {
  justify-content: flex-start;
}
.bubble {
  max-width: 70%;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  word-break: break-word;
}
.msg-row.mine .bubble {
  background: #07c160;
  color: #fff;
}
.msg-row.theirs .bubble {
  background: #fff;
  color: #333;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.08);
}
.msg-img {
  max-width: 400rpx;
  border-radius: 8rpx;
}
.input-bar {
  padding: 16rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}
.input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}
.btn-img, .btn-send {
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  border-radius: 36rpx;
}
.btn-img {
  background: #f0f0f0;
  color: #333;
}
.btn-send {
  background: #07c160;
  color: #fff;
}
